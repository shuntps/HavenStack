# HavenStack - NAS environment template
#
# Copy this file to `nas/.env`, replace every `replace-with-*` value, and
# review all example paths and IDs before deployment.
# Keep the populated `.env` file private and never commit it to source control.

# -----------------------------------------------------------------------------
# Runtime identity and locale
# -----------------------------------------------------------------------------

# IANA timezone used by the containers (for example, America/Toronto).
TZ=America/Toronto

# Static LAN address assigned to the NAS.
NAS_IP=192.168.1.10

# UID and GID used to own application and media files on the NAS.
# Run `id <username>` on the NAS to find the appropriate numeric values.
UID=1000
GID=1000

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Root directory for persistent container configuration and application data.
DATA_PATH=/volume1/docker

# Root directory containing the media library mounted into Plex.
MEDIA_PATH=/volume1/media
