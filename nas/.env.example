# HavenStack — NAS environment template
# Copy this file to nas/.env and replace every placeholder before deployment.
# Never commit your populated .env file.

# General
TZ=America/Toronto
UID=1000
GID=1000

# Storage paths
DATA_PATH=/volume1/docker
MEDIA_PATH=/volume1/media
PROJECT_PATH=/volume1/docker/arcane

# Arcane — generate independent strong random values for both secrets.
ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
JWT_SECRET=replace-with-a-long-random-jwt-secret
