# HavenStack - Unraid environment template
#
# Copy this file to `unraid/.env`, replace every `replace-with-*` value, and
# review all example paths, IDs, networks, and domains before deployment.
# Keep the populated `.env` file private and never commit it to source control.

# -----------------------------------------------------------------------------
# Runtime identity and locale
# -----------------------------------------------------------------------------

# IANA timezone used by the containers (for example, America/Toronto).
TZ=America/Toronto

# Static LAN address assigned to the NAS.
NAS_IP=192.168.1.10

# UID and GID used by services that store their own application data.
# Run `id <username>` on Unraid to find the appropriate numeric values.
UID=1000
GID=1000

# UID and GID that own the media files on the mounted NAS storage.
NAS_UID=1000
NAS_GID=1000

# -----------------------------------------------------------------------------
# Domain
# -----------------------------------------------------------------------------

# Primary domain without a scheme, path, or trailing slash.
DOMAIN=example.com

# Short site/organization name used in generated metadata.
DOMAIN_SLD=example

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------

# Persistent container configuration stored locally on Unraid.
APPDATA_PATH=/mnt/user/appdata

# Mounted media library shared by the Servarr applications and qBittorrent.
HOMELAB_PATH=/mnt/remotes/nas-homelab

# Mounted storage used as the Nextcloud data directory.
CLOUD_PATH=/mnt/remotes/nas_cloud

# Nextcloud manual AIO installation.
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=replace-with-a-strong-admin-password
NEXTCLOUD_DATABASE_PASSWORD=replace-with-a-long-random-database-password
NEXTCLOUD_REDIS_PASSWORD=replace-with-a-long-random-redis-password
NEXTCLOUD_LOG_LEVEL=info
NEXTCLOUD_UPLOAD_LIMIT=17179869184
NEXTCLOUD_MEMORY_LIMIT=2048M
NEXTCLOUD_MAX_TIME=3600

# -----------------------------------------------------------------------------
# Homepage metadata
# -----------------------------------------------------------------------------

SITE_DESCRIPTION="A private, secure, and self-hosted digital haven."
SITE_KEYWORDS="homelab,self-hosted,media,cloud"
SITE_LOCALE=en

# RFC 9116 security.txt metadata. EXPIRES must be a future RFC 3339 timestamp.
SECURITY_TXT_EXPIRES=2027-12-31T23:59:59Z
SECURITY_TXT_CONTACT=mailto:security@example.com

# -----------------------------------------------------------------------------
# Cloudflare
# -----------------------------------------------------------------------------

# Token generated when creating the Cloudflare Tunnel.
CLOUDFLARED_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token

# -----------------------------------------------------------------------------
# Authelia
# -----------------------------------------------------------------------------

# Generate a different random value for each secret, for example with:
# openssl rand -hex 64
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_STORAGE_ENCRYPTION_KEY=replace-with-a-long-random-secret

# -----------------------------------------------------------------------------
# Vaultwarden
# -----------------------------------------------------------------------------

# Use a strong admin token. Prefer an Argon2 PHC string generated by
# Vaultwarden's `hash` command instead of storing a plain-text password.
VAULTWARDEN_ADMIN_TOKEN=replace-with-a-secure-admin-token

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-password

# -----------------------------------------------------------------------------
# qBittorrent VPN (binhex/arch-qbittorrentvpn)
# -----------------------------------------------------------------------------

# Enable the VPN kill switch and tunnel. Keep this set to `yes` for deployment.
VPN_ENABLED=yes

# Credentials supplied by the VPN provider. For PIA, use the dedicated VPN
# username and password rather than the website account credentials.
VPN_USER=replace-with-vpn-username
VPN_PASS=replace-with-vpn-password

# Supported provider identifier and VPN client. This stack is configured for
# PIA over OpenVPN.
VPN_PROV=pia
VPN_CLIENT=openvpn

# LAN and Servarr backend subnet(s) allowed to reach qBittorrent and Privoxy. Use
# CIDR notation and separate multiple networks with commas, without spaces.
LAN_NETWORK=192.168.1.0/24,10.88.40.0/24

# DNS resolvers used inside the VPN container, separated by commas.
NAME_SERVERS=1.1.1.1,1.0.0.1
