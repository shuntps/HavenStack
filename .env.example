# HavenStack environment template
# Copy this file to .env and replace every placeholder before deployment.
# Never commit your populated .env file.

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------

# IANA timezone: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Toronto

# User and group IDs used to run containers on Unraid.
UID=1000
GID=1000

# User and group IDs that own media files on the NAS.
NAS_UID=1000
NAS_GID=1000

# Primary domain without a protocol or trailing slash.
DOMAIN=example.com
DOMAIN_SLD=example

# -----------------------------------------------------------------------------
# Storage paths
# -----------------------------------------------------------------------------

# Persistent application data on Unraid.
APPDATA_PATH=/mnt/user/appdata

# Shared media/data path mounted by the Servarr stack.
HOMELAB_PATH=/mnt/remotes/nas-homelab

# Nextcloud user data directory.
CLOUD_PATH=/mnt/user/nextcloud

# Persistent application data on the NAS.
DATA_PATH=/volume1/docker

# Media library on the NAS.
MEDIA_PATH=/volume1/media

# Parent directory containing Arcane-managed Compose projects.
PROJECT_PATH=/volume1/docker/arcane

# -----------------------------------------------------------------------------
# Homepage metadata
# -----------------------------------------------------------------------------

SITE_DESCRIPTION="A private, secure, and self-hosted digital haven."
SITE_KEYWORDS="homelab,self-hosted,media,cloud"
SITE_LOCALE=en

# RFC 3339 date used by security.txt. Update it before deployment.
SECURITY_TXT_EXPIRES=2027-12-31T23:59:59Z
SECURITY_TXT_CONTACT=mailto:security@example.com

# -----------------------------------------------------------------------------
# Cloudflare
# -----------------------------------------------------------------------------

CLOUDFLARED_TUNNEL_TOKEN=replace-with-cloudflare-tunnel-token
CLOUDFLARE_DDNS_API_TOKEN=replace-with-cloudflare-api-token
CLOUDFLARE_DDNS_DOMAINS=example.com,*.example.com

# -----------------------------------------------------------------------------
# Authelia
# -----------------------------------------------------------------------------

# Generate strong random values, for example: openssl rand -hex 64
AUTH_JWT_SECRET=replace-with-a-long-random-secret
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_STORAGE_ENCRYPTION_KEY=replace-with-a-long-random-secret

# -----------------------------------------------------------------------------
# Vaultwarden
# -----------------------------------------------------------------------------

# Prefer an Argon2 PHC string generated by Vaultwarden's `hash` command.
VAULTWARDEN_ADMIN_TOKEN=replace-with-a-secure-admin-token

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-password

# -----------------------------------------------------------------------------
# Arcane
# -----------------------------------------------------------------------------

# Generate independent strong random values for both secrets.
ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
JWT_SECRET=replace-with-a-long-random-jwt-secret
